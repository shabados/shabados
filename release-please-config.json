{
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "packages": {
    "apps/presenter": {
      "release-type": "node",
      "component": "presenter"
    },
    "apps/web": {
      "release-type": "node",
      "component": "web"
    },
    "apps/library": {
      "release-type": "node",
      "component": "library"
    },
    "packages/sant-lipi": {
      "release-type": "simple",
      "component": "sant-lipi"
    },
    "database": {
      "release-type": "node",
      "component": "database"
    }
  },
  "$comment": "packages/gurmukhi excluded: release-please rust updater cannot read version.workspace=true (Cargo workspace inheritance). TODO: investigate the cargo-workspace plugin, then re-add."
}
